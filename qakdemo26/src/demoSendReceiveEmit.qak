System /*-msglog*/  qakdemo26   
/*
 * -----------------------------------
 * demoSendReceiveEmit.qak
 * -----------------------------------
 */
/*
 * Ogni attore definisce (erdeitando da ActorBasicFsm):
 *  val logger = org.slf4j.LoggerFactory.getLogger(name)
 *  var currentState : State
 *  var currentMsg   : IApplMessage 
 * 
 */      
 
// Definire i messaggi che verranno usati all'inizio

Dispatch msg1 : msg1(ARG)       "da sender a receiver"
Dispatch msg2 : msg2(ARG) 		"da sender a receiver"
Event alarm   : alarm(KIND)     "emesso da sender" 
 
// Contesto dei QActor

Context ctxqakdemo26 ip [host="localhost" port=8010]
  
// Definizione QACtors : receiver, sender, perceiver

QActor receiver context ctxqakdemo26{
		[#  
		   clearlog("./logs/qakdemo26.log") 	//vedi src/main/resources/logback.xml
		#]
	   
	// Automa a Stati Finiti di Moore
	// possiede un solo stato iniziale e una serie di stati finiti
	
	
	// currentMsg è la rappresentazione del messaggio che mi ha portato nel currentstate
	State s0 initial { 	    
		[# logger.info(  "${currentState.stateName} handling $currentMsg"  ) #]
		discardMsg Off  //Off is default: memorizzo i messaggi non attesi 			  
 	}      
 	Goto waitForMsgs   
 	
 	State waitForMsgs{
  		printCurrentMessage color blue
 		[# logger.info(  "${currentState.stateName} handling $currentMsg"  ) #]
 	}
 	
 	// transizione in base all'input
 	Transition t0 whenMsg msg1 -> s2
 				  whenMsg msg2 -> s3 

 	State s2{ 
 		printCurrentMessage color blue
 		[#  logger.info(  "${currentState.stateName} handling $currentMsg"  ) #]
 		// unificazione tra specifica del messaggio che ho dato e currentMsg
 		onMsg( msg1:msg1(ARG) ){
 			println("$name in s2 | msg1:msg1(${payloadArg(0)})") color blue
 			delay 1000  
 		}
   	}    
 	Transition t0 whenMsg msg2 -> s3

 	State s3{ 
 		printCurrentMessage color blue	//msg is received but not elaborated
  		[#  logger.info(  "${currentState.stateName} handling $currentMsg"  ) #]
  		// mi aspetto che il payload del messaggio sia "1"
 		onMsg( msg2:msg2(1) ){ 
 			println("$name in s3 | msg2:msg2(${payloadArg(0)})") color blue
 		} 
   	}
   	// ritorno nello stato di attesa con un epsilon-move
    Goto waitForMsgs      
}    
      
QActor sender context ctxqakdemo26{
	[# var emitEvents = true   
	   var DT         = 1000L; 
 	#]
	State s0 initial { 	
		[# logger.info(  "${currentState.stateName} handling $currentMsg"  ) #]
		println( "$name sends msg1: msg1(1)... ") color green
		[# logger.info(  "${currentState.stateName} sending msg1:msge1(1)"  ) #]
		// l'attore sender invia un messaggio msg1 al receiver
 		forward receiver -m msg1 : msg1(1)
		delay 300
		println( "$name sends msg1: msg1(2)... ") color green
		[# logger.info(  "${currentState.stateName} sending msg1:msge1(2)"  ) #]
		forward receiver -m msg1 : msg1(2)
	} 
	// invece che aspettare un input per cambiare di stato, aspettiamo per un intervallo
	// pari a DT per passare allo stato successivo
	Transition t0 
		whenTimeVar  DT -> sendothermsgs
	
	State sendothermsgs{
		[# logger.info(  "${currentState.stateName} handling $currentMsg"  ) #]
		println( "$name sends msg2 after $DT ... ") color green
		[# logger.info(  "${currentState.stateName} sending msg2:msg2(1)"  ) #]
		forward receiver -m msg2 : msg2(1)		  	 
		if [# emitEvents #] {
			[# logger.info(  "${currentState.stateName} emits alarm"  ) #]
			emit alarm : alarm( fire )
		}
	}
}

QActor perceiver context ctxqakdemo26{
	State s0 initial { 	
		[# logger.info(  "${currentState.stateName} handling $currentMsg"  ) #]
	}
	Goto waitForEvents
	
	// attore che percepisce degli eventi
	State waitForEvents{
		printCurrentMessage color magenta
		[# logger.info(  "${currentState.stateName} handling $currentMsg"  ) #]
	}
	Transition t0  
		whenEvent alarm -> handleEvent
	
	// quando riceve un alarm passa allo stato di gestione dell'evento
	State handleEvent{
		printCurrentMessage color magenta
		[# logger.info(  "${currentState.stateName} perceives $currentMsg"  ) #]
		println("perceiver ENDS THE SYSTEM") color magenta
		//[# System.exit(0) #]
	}
	Goto waitForEvents
}  

 
